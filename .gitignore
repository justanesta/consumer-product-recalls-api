# Python (anchor build/dist to repo root so they don't match project_scope/build/ docs)
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
/build/
/dist/

# Virtual env / uv
.venv/

# Env / secrets (never commit a real DSN — gitleaks also guards this)
.env
.env.*
!.env.example

# Local / private (not checked in)
CLAUDE.local.md
.claude/settings.local.json

# Build-spec docs: re-include despite a broad `build/` in the user's global ~/.config/git/ignore.
# (Git can re-include a directory excluded by a pattern as long as no PARENT dir is excluded.)
!project_scope/build/

# Tool caches / coverage
.ruff_cache/
.pytest_cache/
.pyright/
htmlcov/
.coverage
.coverage.*
coverage.xml

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
