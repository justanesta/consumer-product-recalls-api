# Read-only Neon DSN for the API role, asyncpg driver. Copy to `.env` and fill in.
# TODO(build): confirm the exact role name (recalls_readonly), pooled-vs-direct endpoint, and the env
# var name with the pipeline operator before wiring db.py — see the pipeline repo's
# project_scope/serving-layer-gold-readiness-plan.md (R1) and project_scope/build/06-deployment-and-ops.md.
# NEVER commit a real DSN; gitleaks guards this and `.env` is gitignored.
# A Neon-console DSN pasted verbatim (postgresql://...?sslmode=require&channel_binding=require) also
# works: db.normalize_dsn forces the +asyncpg driver, strips those libpq params, and enables TLS.
NEON_DATABASE_URL_RO=postgresql+asyncpg://recalls_readonly:CHANGE_ME@HOST/neondb?ssl=require

ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=console